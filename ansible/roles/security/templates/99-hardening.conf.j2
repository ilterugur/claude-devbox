# Managed by Ansible (claude-devbox) — do not edit by hand.
# Lockout recovery: from the Hetzner console/rescue system, edit this file to add
# `AllowUsers root` (and temporarily set PermitRootLogin yes), then `systemctl
# restart ssh`.
PermitRootLogin no
PasswordAuthentication no
KbdInteractiveAuthentication no
PubkeyAuthentication yes
AllowUsers {{ ([operator_user] + (profiles | default([]) | map(attribute='user') | list)) | join(' ') }}
