# Managed by Ansible (claude-devbox). Sourced by interactive shells (~/.bashrc) and the
# always-on Remote Control services (EnvironmentFile=). Holds ALL Hindsight provider env
# for this profile — the daemon (uvx hindsight-embed) inherits this environment when the
# plugin launches it. HINDSIGHT_API_LLM_* is the DEFAULT LLM (used by every operation);
# retain/reflect/consolidation LLMs, the embedder, and the reranker can each point at a
# DIFFERENT provider. HINDSIGHT_USER_ID becomes the 'profile:' memory tag.
# NOTE: a daemon that is already running must be RESTARTED to pick up provider changes
# (it persists with daemonIdleTimeout:0): `uvx hindsight-embed -p claude-code daemon stop`
# then `... daemon start`.
HINDSIGHT_USER_ID={{ item.user }}
HINDSIGHT_API_PORT={{ hindsight_base_port | default(9077) + idx }}

# ── Default LLM (every operation uses this unless overridden below) ────────────
HINDSIGHT_API_LLM_PROVIDER={{ hindsight_llm_provider }}
{% if hindsight_llm_api_key | default('') | length > 0 %}
HINDSIGHT_API_LLM_API_KEY={{ hindsight_llm_api_key }}
{% endif %}
{% if hindsight_llm_model | default('') | length > 0 %}
HINDSIGHT_API_LLM_MODEL={{ hindsight_llm_model }}
{% endif %}
{% if hindsight_llm_base_url | default('') | length > 0 %}
HINDSIGHT_API_LLM_BASE_URL={{ hindsight_llm_base_url }}
{% endif %}
{% if hindsight_llm_max_concurrent | default('') | string | length > 0 %}
HINDSIGHT_API_LLM_MAX_CONCURRENT={{ hindsight_llm_max_concurrent }}
{% endif %}

# ── Per-operation LLM overrides (optional; empty = use the default LLM above) ──
{% set op_overrides = {
     'RETAIN': hindsight_retain_llm | default({}),
     'REFLECT': hindsight_reflect_llm | default({}),
     'CONSOLIDATION': hindsight_consolidation_llm | default({})
   } %}
{% for op, ov in op_overrides.items() %}
{% if ov.provider | default('') | length > 0 %}
HINDSIGHT_API_{{ op }}_LLM_PROVIDER={{ ov.provider }}
{% if ov.api_key | default('') | length > 0 %}
HINDSIGHT_API_{{ op }}_LLM_API_KEY={{ ov.api_key }}
{% endif %}
{% if ov.model | default('') | length > 0 %}
HINDSIGHT_API_{{ op }}_LLM_MODEL={{ ov.model }}
{% endif %}
{% if ov.base_url | default('') | length > 0 %}
HINDSIGHT_API_{{ op }}_LLM_BASE_URL={{ ov.base_url }}
{% endif %}
{% endif %}
{% endfor %}

# ── Embeddings (empty = the daemon's built-in LOCAL embedder; set a provider to
#    override — a REMOTE provider sends memory text off the box) ────────────────
{% set emb = hindsight_embeddings | default({}) %}
{% if emb.provider | default('') | length > 0 %}
{% set ep = emb.provider | upper %}
HINDSIGHT_API_EMBEDDINGS_PROVIDER={{ emb.provider }}
{% if emb.model | default('') | length > 0 %}
HINDSIGHT_API_EMBEDDINGS_{{ ep }}_MODEL={{ emb.model }}
{% endif %}
{% if emb.api_key | default('') | length > 0 %}
HINDSIGHT_API_EMBEDDINGS_{{ ep }}_API_KEY={{ emb.api_key }}
{% endif %}
{% if emb.base_url | default('') | length > 0 %}
HINDSIGHT_API_EMBEDDINGS_{{ ep }}_BASE_URL={{ emb.base_url }}
{% endif %}
{% endif %}

# ── Reranker (optional; off by default) ───────────────────────────────────────
{% set rr = hindsight_reranker | default({}) %}
{% if rr.provider | default('') | length > 0 %}
{% set rp = rr.provider | upper %}
HINDSIGHT_API_RERANKER_PROVIDER={{ rr.provider }}
{% if rr.model | default('') | length > 0 %}
HINDSIGHT_API_RERANKER_{{ rp }}_MODEL={{ rr.model }}
{% endif %}
{% if rr.api_key | default('') | length > 0 %}
HINDSIGHT_API_RERANKER_{{ rp }}_API_KEY={{ rr.api_key }}
{% endif %}
{% if rr.base_url | default('') | length > 0 %}
HINDSIGHT_API_RERANKER_{{ rp }}_BASE_URL={{ rr.base_url }}
{% endif %}
{% if rr.max_candidates | default('') | string | length > 0 %}
HINDSIGHT_API_RERANKER_MAX_CANDIDATES={{ rr.max_candidates }}
{% endif %}
{% endif %}

# ── Search backends (optional; empty = daemon defaults) ───────────────────────
{% if hindsight_text_search_extension | default('') | length > 0 %}
HINDSIGHT_API_TEXT_SEARCH_EXTENSION={{ hindsight_text_search_extension }}
{% endif %}
{% if hindsight_vector_extension | default('') | length > 0 %}
HINDSIGHT_API_VECTOR_EXTENSION={{ hindsight_vector_extension }}
{% endif %}

# ── Raw passthrough: any HINDSIGHT_API_* key -> value, rendered verbatim ───────
#    Escape hatch for knobs without a dedicated var (onnx embedding params, output
#    language, etc.). Emitted last.
{% for k, v in (hindsight_extra_env | default({})).items() %}
{{ k }}={{ v }}
{% endfor %}
