{# Managed by Ansible (claude-devbox). One unit per (profile, project). #}
{# Merge global rc_limits / rc_build_env defaults with per-server overrides. #}
{% set L = (rc_limits | default({})) | combine(item.1.limits | default({})) %}
{% set BENV = (rc_build_env | default({})) | combine(item.1.build_env | default({})) %}
{% set ID = item.0.user ~ '-' ~ item.1.project %}
[Unit]
Description=Claude remote-control ({{ ID }})
After=network-online.target tailscaled.service
Wants=network-online.target
{% if rc_autorestart | default(true) %}
{# Cap restart churn: at most rc_start_limit_burst restarts per interval, else give up. #}
StartLimitIntervalSec={{ rc_start_limit_interval | default(600) }}
StartLimitBurst={{ rc_start_limit_burst | default(10) }}
{% endif %}

[Service]
{% if rc_autorestart | default(true) %}
{# Self-heal: a oneshot+RemainAfterExit unit goes to "failed (oom-kill)" and STAYS
   down when the cgroup is OOM-killed. Instead we run a blocking monitor as the main
   process: ExecStartPre spawns the detached tmux server, ExecStart blocks while that
   session lives and exits non-zero the moment it dies (OOM/kill/crash), so
   Restart=on-failure brings the whole unit back in RestartSec. #}
Type=simple
ExecStartPre=/usr/local/bin/claude-rc-wrapper {{ ID }}
ExecStart=/usr/local/bin/claude-rc-monitor {{ ID }}
Restart=on-failure
RestartSec={{ rc_restart_sec | default(10) }}
{% else %}
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/bin/claude-rc-wrapper {{ ID }}
{% endif %}
User={{ item.0.user }}
Environment=HOME=/home/{{ item.0.user }}
Environment=PATH=/home/{{ item.0.user }}/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
{# Do NOT set CLAUDE_CONFIG_DIR: it would make claude look for config at
   ~/.claude/.claude.json, but login + interactive sessions use Claude's default
   (~/.claude.json in HOME). The run script defaults its credential-check path to
   ~/.claude on its own. #}
Environment=CLAUDE_RC_PROJECT_DIR=/home/{{ item.0.user }}/projects/{{ item.1.project }}
{# Quote values: names like "Verti Monorepo" contain spaces — unquoted, systemd
   parses everything after the space as a second, invalid env assignment. #}
Environment="CLAUDE_RC_NAME={{ item.1.name | default(item.0.user ~ ' · ' ~ item.1.project) }}"
Environment=CLAUDE_RC_SPAWN={{ item.1.spawn | default('worktree') }}
Environment=CLAUDE_RC_CAPACITY={{ item.1.capacity | default(4) }}
{# Hindsight (when enabled): load the profile's HINDSIGHT_USER_ID + HINDSIGHT_API_LLM_* so the memory hooks/daemon work in RC sessions too. The leading '-' makes it optional, so the unit is unaffected when Hindsight is disabled and the file is absent. uvx resolves via `mise activate --shims` in claude-rc-run. #}
EnvironmentFile=-/home/{{ item.0.user }}/.hindsight/llm.env
{% for k, v in BENV.items() %}
Environment="{{ k }}={{ v }}"
{% endfor %}
ExecStop=/usr/bin/tmux -L claude-rc-{{ ID }} kill-server
{% if rc_resume_on_boot | default(true) %}
{# Trigger the boot/recovery orchestrator on EVERY start — including Restart=
   auto-restarts after an OOM, which do NOT re-pull Wants= dependencies (so a plain
   Wants= would only fire on a clean `systemctl start`, not on self-heal). The '+'
   runs it as root (the service runs as the profile user, which can't call
   systemctl); --no-block returns immediately so it never delays the unit becoming
   active, and the companion is idempotent (it skips sessions already running). #}
ExecStartPost=+/usr/bin/systemctl start --no-block claude-rc-resume-{{ ID }}.service
{% endif %}
{# ── Resource control (systemd cgroup) — keep one build from taking the box ── #}
{% if L.memory_high | default('') %}MemoryHigh={{ L.memory_high }}
{% endif %}
{%- if L.memory_max | default('') %}MemoryMax={{ L.memory_max }}
{% endif %}
{%- if L.memory_swap_max | default('') %}MemorySwapMax={{ L.memory_swap_max }}
{% endif %}
{%- if L.cpu_weight | default('') %}CPUWeight={{ L.cpu_weight }}
{% endif %}
{%- if L.cpu_quota | default('') %}CPUQuota={{ L.cpu_quota }}
{% endif %}
{%- if L.io_weight | default('') %}IOWeight={{ L.io_weight }}
{% endif %}
{%- if L.nice is defined and L.nice != '' %}Nice={{ L.nice }}
{% endif %}
{%- if L.oom_score_adjust is defined and L.oom_score_adjust != '' %}OOMScoreAdjust={{ L.oom_score_adjust }}
{% endif %}
[Install]
WantedBy=multi-user.target
